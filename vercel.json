{
  "trailingSlash": false,
  "redirects": [
    { "source": "/famous-iq/einstein-iq-detailed", "destination": "/famous-iq/albert-einstein", "permanent": true },
    { "source": "/famous-iq/aoc-detailed", "destination": "/famous-iq/alexandria-ocasio-cortez", "permanent": true },
    { "source": "/famous-iq/steph-curry-detailed", "destination": "/famous-iq/stephen-curry", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!assets|favicon\\.ico|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
